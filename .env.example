# Mot de passe du compte root (login UI root@pam), appliqué au premier démarrage.
# Laisser vide pour le définir manuellement via : docker exec -it pdm passwd
PDM_ROOT_PASSWORD=changeme

# Port HTTPS de l'interface web (par défaut 8443).
# PDM_PORT=8443

# Masquer le popup "Aucun abonnement en cours de validité" au login (true/false).
# DISABLE_SUBSCRIPTION_NAG=false

# Masquer l'onglet "Mises à jour" de l'UI (true/false, défaut true). Les MAJ de PDM
# se font en changeant d'image (docker compose pull), pas via apt dans le conteneur.
# Mettre à false uniquement si tu sais ce que tu fais.
# DISABLE_UPDATES_TAB=true

# Masquer les boutons "Redémarrer"/"Arrêter" de l'UI (true/false, défaut true).
# Le cycle de vie du conteneur se gère via Docker (docker restart/stop).
# DISABLE_POWER_BUTTONS=true

# Masquer l'entrée de menu "Abonnement" locale (true/false, défaut true).
# Sans intérêt ici ; ne touche pas à "Subscription Registry" (gestion des remotes).
# DISABLE_SUBSCRIPTION_PANEL=true

# Verrouiller la vue "Réseau et heure" en lecture seule (true/false, défaut true).
# Retire l'édition heure/DNS et la section Interfaces réseau (gérés via Docker).
# DISABLE_NETWORK_EDIT=true

# Fuseau horaire du conteneur (ex: Europe/Paris). Appliqué à chaque démarrage.
# TZ=Europe/Paris
